# Supabase — public connection (safe to commit as example)
VITE_SUPABASE_URL=https://rzlvuaqbvfzkunbyyvbc.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_yhsz0rmi4z6uMS9SxFLR8Q_1mfTnBmH

# Google OAuth — configured in Supabase Auth dashboard, not needed in frontend env

# Feature flags — set to "true" once the corresponding service is configured
VITE_FEATURE_GOOGLE_CALENDAR=false
VITE_FEATURE_GOOGLE_MEET=false
VITE_FEATURE_WHATSAPP=false
VITE_FEATURE_TRANSCRIPTION=false
VITE_FEATURE_AI_EXTRACTION=false
VITE_FEATURE_PUSH_NOTIFICATIONS=false

# OneSignal (push notifications) — only needed on the client if push is enabled
VITE_ONESIGNAL_APP_ID=

# Cloudflare R2 — public CDN URL for shared recordings/attachments.
# NOT a secret. The R2 access keys live in Supabase secrets, NEVER here:
#   R2_ACCOUNT_ID, R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY, R2_BUCKET_NAME.
# See SPEC §28 #9 + docs/recordings-architecture-prompt.md.
VITE_R2_PUBLIC_URL=https://pub-<hash>.r2.dev
